<?xml version="1.0" ?>
<sdf version="1.6">
  <model name="Blue_Box">
    <self_collide>false</self_collide>
    <link name="link">
      <inertial>
        <mass>1.0</mass>
      </inertial>
      <collision name="collision">
      <geometry>
        <mesh>
          <uri>model://Blue_Box/meshes/Blue_Box.stl</uri>
          <scale>0.001 0.001 0.001</scale>
        </mesh>
      </geometry>
      <surface>
        <contact>
          <ode>
            <max_vel>0.1</max_vel>
            <min_depth>0.001</min_depth>
          </ode>
        </contact>
      </surface>
      </collision>
      <visual name="visual">
        <geometry>
          <mesh>
            <uri>model://Blue_Box/meshes/Blue_Box.stl</uri>
            <scale>0.001 0.001 0.001</scale>
          </mesh>
        </geometry>
	<material>
	  <ambient>0.1 0.2 0.7 1.0</ambient> <!-- Cool blue ambient color -->
	  <diffuse>0.1 0.3 0.8 1.0</diffuse> <!-- Brighter blue diffuse color -->
	  <specular>0.3 0.3 0.4 1.0</specular> <!-- Soft gray-blue highlights -->
	  <emissive>0.0 0.0 0.0 1.0</emissive> <!-- No emissive color -->
	</material>
      </visual>
    </link>
    <static>0</static>
  </model>
</sdf>
